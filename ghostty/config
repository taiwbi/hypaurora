# --- Fonts ---
font-family = "FantasqueSansMono Nerd Font"
font-family = "Vazir Code Hack"

font-size = 13

# --- Font Fallbacks ---
font-family = "Vazir Code Hack"

# --- Cell Dimensions ---
adjust-cell-height = 4

# --- Window ---
window-width = 150
window-height = 32
window-padding-x = 0
window-padding-y = 0
background-opacity = 1

# --- Mouse ---
mouse-hide-while-typing = true

# --- Theme ---
window-theme = ghostty
theme = light:hypaurora-light,dark:hypaurora-dark
