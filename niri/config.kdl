// ============================================================================
// NIRI CONFIGURATION - Base for illogical-impulse (ii)
// ============================================================================
// Minimal base config - customize to your needs
// Wiki: https://github.com/YaLTeR/niri/wiki/Configuration:-Introduction
// ============================================================================

prefer-no-csd

hotkey-overlay {
    skip-at-startup
}

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

// Outputs (example - disabled by default)
// Run `niri msg outputs` inside a niri session to see connector names and modes.
// Then edit and uncomment this block to pin a specific monitor layout.

output "eDP-1" {
    // off
    mode "1920x1080@59.93"
    scale 1.0
    transform "normal"
    position x=0 y=0
    variable-refresh-rate // on-demand=true
    focus-at-startup
    background-color "#1e1e1e"
    backdrop-color "#1e1e1e"
    // variable-refresh-rate
}

// ============================================================================
// INPUT
// ============================================================================

input {
    keyboard {
        xkb {
            layout "us,ir"
            options "caps:escape"
        }
        track-layout "window"

        repeat-delay 250
        repeat-rate 50
    }
    
    mouse {
        accel-profile "flat"
        accel-speed 0.8
        scroll-factor 1.0
    }

    touchpad {
        accel-profile "flat"
        accel-speed 0.8
        scroll-factor 1.0
        scroll-method "two-finger"
        natural-scroll
        tap
        dwt // disable when typing
        drag true // tap and drag
        drag-lock
    }

    mod-key "Super"
    mod-key-nested "Alt"
}

// ============================================================================
// LAYOUT
// ============================================================================

layout {
    gaps 12
    background-color "transparent"
    center-focused-column "never"
    
    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }
    
    default-column-width { 
        proportion 1.0
    }
    
    border {
        off
        width 4
        active-color   "#707070"
        inactive-color "#d0d0d0"
        urgent-color   "#cc4444"
    }
    
    focus-ring {
        off
        width 1
        active-color   "#808080"
        inactive-color "#505050"
    }
    
    shadow {
       // off
        softness 30
        spread 5
        offset x=0 y=5
        color "#0007"
    }
    
    struts { }
}

gestures {
    hot-corners {
        // off
    }
}

cursor {
    // xcursor-theme "capitaine-cursors-light"
    // xcursor-size 24
    // hide-when-typing


    xcursor-theme "MacOS-Tahoe-Cursor"
    xcursor-size 32

    hide-when-typing
    hide-after-inactive-ms 5000
}

overview {
    zoom 0.75
}

// ============================================================================
// WINDOW RULES
// ============================================================================

window-rule {
    geometry-corner-radius 16
    clip-to-geometry true
}

window-rule { 
    match is-active=false
    opacity 0.9
}

window-rule {
    match app-id="org.gnome.Shotwell" title="Modify Tags"
    min-height 400
}

window-rule {
    match app-id="org.kde.kdeconnect.daemon"
    open-floating true

    min-width 300
    max-width 400
    min-height 150
    max-height 250
}

// ============================================================================
// ANIMATIONS
// ============================================================================

animations {
    workspace-switch {
        spring damping-ratio=0.92 stiffness=800 epsilon=0.0001
    }
    
    window-open {
        spring damping-ratio=0.92 stiffness=900 epsilon=0.0001
    }
    
    window-close {
        spring damping-ratio=0.95 stiffness=1000 epsilon=0.0001
    }
    
    horizontal-view-movement {
        spring damping-ratio=0.90 stiffness=800 epsilon=0.0001
    }
    
    window-movement {
        spring damping-ratio=0.96 stiffness=850 epsilon=0.0001
    }
}

// ============================================================================
// ENVIRONMENT
// ============================================================================

environment {
    ELECTRON_OZONE_PLATFORM_HINT "auto"


    QT_QPA_PLATFORM "wayland"
    GDMSESSION "GNOME"
    XDG_SESSION_DESKTOP "GNOME"
    XDG_CURRENT_DESKTOP "GNOME"

    ELECTRON_OZONE_PLATFORM_HINT "auto"

    // systemctl --user enable --now gcr-ssh-agent.socket
    SSH_AUTH_SOCK "/run/user/1000/gcr/ssh"
    
    // Quickshell Python virtual environment
    ILLOGICAL_IMPULSE_VIRTUAL_ENV "$HOME/.local/state/quickshell/.venv"

    DISPLAY null
}

// ============================================================================
// STARTUP
// ============================================================================

// Import XDG_MENU_PREFIX to systemd for Dolphin file associations (must be first)
spawn-at-startup "bash" "-c" "systemctl --user import-environment XDG_MENU_PREFIX && kbuildsycoca6"

spawn-at-startup "bash" "-c" "wl-paste --watch cliphist store &"
spawn-at-startup "/usr/lib/mate-polkit/polkit-mate-authentication-agent-1"
spawn-at-startup "qs" "-c" "ii"

// ============================================================================
// KEYBINDINGS
// ============================================================================

binds {
    // System
    Mod+Tab repeat=false { toggle-overview; }
    Mod+Shift+E { quit; }
    Mod+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }
    
    // ii Window Switcher (Alt+Tab)
    Alt+Tab { spawn "qs" "-c" "ii" "ipc" "call" "altSwitcher" "next"; }
    Alt+Shift+Tab { spawn "qs" "-c" "ii" "ipc" "call" "altSwitcher" "previous"; }
    
    // ii Overlay
    Super+G { spawn "qs" "-c" "ii" "ipc" "call" "overlay" "toggle"; }

    // ii Overview (daemon)
    Mod+M repeat=false { spawn "qs" "-c" "ii" "ipc" "call" "overview" "toggle"; }
    
    // ii Clipboard
    Mod+V { spawn "qs" "-c" "ii" "ipc" "call" "clipboard" "toggle"; }
    
    // ii Lock screen
    Mod+Alt+L allow-when-locked=true { spawn "qs" "-c" "ii" "ipc" "call" "lock" "activate"; }
    
    // ii Region tools
    Mod+Shift+S { spawn "qs" "-c" "ii" "ipc" "call" "region" "screenshot"; }
    Mod+Shift+X { spawn "qs" "-c" "ii" "ipc" "call" "region" "ocr"; }
    Mod+Shift+A { spawn "qs" "-c" "ii" "ipc" "call" "region" "search"; }
    
    // ii Wallpaper selector
    Ctrl+Alt+T { spawn "qs" "-c" "ii" "ipc" "call" "wallpaperSelector" "toggle"; }
    
    // ii Settings
    Mod+Comma { spawn "qs" "-c" "ii" "ipc" "call" "settings" "open"; }
    
    // ii Cheatsheet
    Mod+Slash { spawn "qs" "-c" "ii" "ipc" "call" "cheatsheet" "toggle"; }

    // Toggle Keyboard Layout
    Mod+space { spawn "niri" "msg" "action" "switch-layout" "next"; }
    
    // Applications
    Mod+Return { spawn "ghostty" "--gtk-titlebar=false"; }
    Mod+backslash { spawn "~/Documents/hypaurora/code/nvim.sh" "kitty"; }
    Mod+E { spawn "nautilus"; }
    Mod+B { spawn "flatpak" "run" "com.brave.Browser" "--new-window"; }
    Mod+P { spawn "gnome-control-center"; }
    
    // Window management
    Mod+Q repeat=false { spawn "bash" "-c" "$HOME/.config/quickshell/ii/scripts/close-window.sh"; }
    Mod+D { maximize-column; }
    Mod+F { fullscreen-window; }
    Mod+C { toggle-window-floating; }
    Mod+Z { switch-preset-column-width; }

    // Focus
    Mod+Left { focus-column-left; }
    Mod+Right { focus-column-right; }
    Mod+Up { focus-window-up; }
    Mod+Down { focus-window-down; }
    Mod+H { focus-column-left; }
    Mod+J { focus-workspace-down; }
    Mod+K { focus-workspace-up; }
    Mod+L { focus-column-right; }

    Mod+A { focus-column-left; }
    Mod+S { focus-column-right; }

    Mod+WheelScrollDown cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp cooldown-ms=150 { focus-workspace-up; }
    Mod+Shift+WheelScrollDown cooldown-ms=150 { focus-column-right; }
    Mod+Shift+WheelScrollUp cooldown-ms=150 { focus-column-left; }
    
    // Move windows
    Mod+Shift+Left { move-column-left; }
    Mod+Shift+Right { move-column-right; }
    Mod+Shift+Up { move-workspace-up; }
    Mod+Shift+Down { move-workspace-down; }
    Mod+Shift+H { move-column-left; }
    Mod+Shift+J { move-workspace-down; }
    Mod+Shift+K { move-workspace-up; }
    Mod+Shift+L { move-column-right; }
    
    // Workspaces
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }
    
    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; }
    Mod+Shift+5 { move-column-to-workspace 5; }
    
    // Screenshots (native)
    Print { screenshot; }
    Ctrl+Print { screenshot-screen; }
    Alt+Print { screenshot-window; }
    
    // ========================================================================
    // HARDWARE KEYS - Audio, Brightness, Media
    // ========================================================================
    // These use ii IPC so the OSD (On Screen Display) shows feedback
    
    // Volume (hardware keys)
    XF86AudioRaiseVolume allow-when-locked=true { spawn "qs" "-c" "ii" "ipc" "call" "audio" "volumeUp"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "qs" "-c" "ii" "ipc" "call" "audio" "volumeDown"; }
    XF86AudioMute allow-when-locked=true { spawn "qs" "-c" "ii" "ipc" "call" "audio" "mute"; }
    XF86AudioMicMute allow-when-locked=true { spawn "qs" "-c" "ii" "ipc" "call" "audio" "micMute"; }
    
    // Brightness (hardware keys)
    XF86MonBrightnessUp { spawn "qs" "-c" "ii" "ipc" "call" "brightness" "increment"; }
    XF86MonBrightnessDown { spawn "qs" "-c" "ii" "ipc" "call" "brightness" "decrement"; }
    
    // Media playback (hardware keys)
    XF86AudioPlay { spawn "qs" "-c" "ii" "ipc" "call" "mpris" "playPause"; }
    XF86AudioPause { spawn "qs" "-c" "ii" "ipc" "call" "mpris" "playPause"; }
    XF86AudioNext { spawn "qs" "-c" "ii" "ipc" "call" "mpris" "next"; }
    XF86AudioPrev { spawn "qs" "-c" "ii" "ipc" "call" "mpris" "previous"; }
    
    // Keyboard alternatives for media (for keyboards without media keys)
    Mod+Shift+M { spawn "qs" "-c" "ii" "ipc" "call" "audio" "mute"; }
    Mod+Shift+P { spawn "qs" "-c" "ii" "ipc" "call" "mpris" "playPause"; }
    Mod+Shift+N { spawn "qs" "-c" "ii" "ipc" "call" "mpris" "next"; }
    Mod+Shift+B { spawn "qs" "-c" "ii" "ipc" "call" "mpris" "previous"; }
}

// Layer rules for ii backdrop visibility during Niri overview
layer-rule {
    match namespace="quickshell:iiBackdrop"
    place-within-backdrop true
    opacity 1.0
}

layer-rule {
    match namespace="quickshell:wBackdrop"
    place-within-backdrop true
    opacity 1.0
}
