// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // UI and Buffer =============================================
  "buffer_font_family": "Dank Mono",
  "buffer_font_fallbacks": ["Vazir Code Hack"],
  "buffer_font_size": 17,
  "buffer_line_height": "comfortable",

  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
  "experimental.theme_overrides": {
    "syntax": {
      "comment": {
        "font_style": "italic",
      },
      "comment.doc": {
        "font_style": "italic",
      },
    },
  },
  "icon_theme": {
    "mode": "system",
    "light": "Monospace Icon Theme - Light",
    "dark": "Monospace Icon Theme - Dark",
  },
  "selection_highlight": false,
  "cursor_blink": true,

  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 15,

  "vertical_scroll_margin": 6.0,
  "colorize_brackets": false,
  "show_whitespaces": "trailing",
  "indent_guides": {
    "enabled": true,
  },
  "minimap": {
    "show": "never",
  },

  // Agent =====================================================
  "agent": {
    // chat window
    "default_model": {
      "provider": "openrouter",
      "model": "qwen/qwen3-coder-30b-a3b-instruct",
    },
    "default_profile": "minimal",
    // inline assistant
    "inline_assistant_model": {
      "provider": "openrouter",
      "model": "qwen/qwen3-coder-30b-a3b-instruct",
      "enable_thinking": false,
    },
    "inline_alternatives": [
      {
        "provider": "openrouter",
        "model": "qwen/qwen3-coder-next",
      },
      {
        "provider": "openrouter",
        "model": "minimax/minimax-m2.5",
      },
    ],
  },
  "agent_ui_font_size": 15.0,
  // edit predictions
  "show_edit_predictions": true,
  "edit_predictions": {
    "mode": "eager",
    "provider": "zed",
  },

  // Terminal ==================================================
  "terminal": {
    "font_family": "DankMono Nerd Font Mono",
    "font_size": 14,
    "font_features": {
      "ss16": true,
      "dlig": true,
      "calt": true,
      "CLIK": true,
      "JSPT": true,
      "PHPX": true,
    },
    "font_fallbacks": ["Vazir Code Hack", "Symbols Nerd Font", "Noto Emoji"],
    "line_height": "comfortable",
  },
  // Behaviour =================================================
  "vim_mode": true,
  "base_keymap": "VSCode",
  "relative_line_numbers": "enabled",
  "use_smartcase_search": true,
  "auto_indent_on_paste": true,
  "autosave": "on_focus_change",
  "restore_on_startup": "launchpad",
  "tab_bar": {
    "show": false,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": true,
  },
  "sticky_scroll": {
    "enabled": false,
  },
  "gutter": {
    "line_numbers": true,
  },
  "git_panel": {
    "tree_view": true,
  },

  // LSP and Language Server ===================================
  "languages": {
    "PHP": {
      "formatter": {
        "external": {
          "command": "bash",
          "arguments": [
            "-c",
            "cat > {buffer_path} && ./vendor/bin/pint --quiet {buffer_path} && cat {buffer_path}",
          ],
        },
      },
      "language_servers": ["phptools", "!intelephense", "!phpactor", "..."],
    },
    "Blade": {
      "language_servers": ["phptools", "!intelephense", "!phpactor", "..."],
    },
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "php": "html",
          "blade": "html",
        },
        "experimental": {
          "classRegex": [
            // php
            "class=\"([^\"]*)\"",
            "class='([^']*)'",
            "class=\\\"([^\\\"]*)\\\"",
            // blade
            "class=\"([^\"]*)\"",
            "class='([^']*)'",
            "class=\\\"([^\\\"]*)\\\"",
            "@class\\(\\[([^\\]]*)\\]\\)",
          ],
        },
      },
    },
  },
}
